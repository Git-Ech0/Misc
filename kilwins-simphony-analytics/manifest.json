{
  "manifest_version": 3,
  "name": "Kilwins Simphony Analytics",
  "description": "Drop a Simphony report .xlsx export onto the dashboard and get actionable store-management recommendations. 100% local, no network calls.",
  "version": "2.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Kilwins Simphony Analytics dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": ["tabs"]
}
